# Production template — copy values into EasyPanel (backend service env). Never commit real secrets.

JWT_SECRET=generate-with-openssl-rand-base64-32
JWT_TTL_MINUTES=720
USE_FAKE_REPO=0

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-or-secret-key

LEGALDESK_BASE=https://legaldesk.mbclaw.com.br/API/v1/ODataGERALADV
LEGALDESK_USER=integracao
LEGALDESK_PASSWORD=

# Comma-separated; must include the public frontend URL (HTTPS).
CORS_ORIGINS=https://rumo-frontend.xem1qi.easypanel.host

# Used only when running scripts/seed.py (one-time or password rotation).
SEED_ADMIN_PASSWORD=
SEED_MBC_PASSWORD=
SEED_DEMO_PASSWORD=
