JWT_SECRET=change-me-in-prod
JWT_TTL_MINUTES=720

# Dev-only: run with an in-memory repo (seeded demo users), no Supabase needed.
# Set to 1 to try the app locally with zero external setup. NEVER enable in prod.
USE_FAKE_REPO=0

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
LEGALDESK_BASE=https://legaldesk.mbclaw.com.br/API/v1/ODataGERALADV
LEGALDESK_USER=integracao
LEGALDESK_PASSWORD=

# --- SISJURI Oracle DB (see docs/SISJURI_DB.md + docs/SISJURI_QUERIES.md) ---
# Reachable only from MBC-LDESK01 (private OCI VCN). See §10 for egress options.
# Used by a SisjuriDbSource (tunneled) OR the on-server push agent.
SISJURI_DSN=172.16.237.9:1521/cdbp01_pdb1.submbc.vcnmbc.oraclevcn.com
SISJURI_USER=
SISJURI_PASSWORD=
# Option A (push agent -> VPS ingest): shared bearer token for /api/ingest
INGEST_TOKEN=
# Where ingested SISJURI snapshots are stored (read by SisjuriDbSource)
SNAPSHOT_DIR=data/snapshots

CORS_ORIGINS=http://localhost:5173
